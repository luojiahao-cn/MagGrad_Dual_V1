{
  "configurations": [
    {
      "name": "STM32H743",
      "compilerPath": "arm-none-eabi-gcc",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "gcc-arm",
      "includePath": [
        "${workspaceFolder}/Core/Inc",
        "${workspaceFolder}/USB_DEVICE/App",
        "${workspaceFolder}/USB_DEVICE/Target",
        "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc",
        "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc/Legacy",
        "${workspaceFolder}/Middlewares/ST/STM32_USB_Device_Library/Core/Inc",
        "${workspaceFolder}/Middlewares/ST/STM32_USB_Device_Library/Class/CDC/Inc",
        "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32H7xx/Include",
        "${workspaceFolder}/Drivers/CMSIS/Include"
      ],
      "defines": [
        "USE_PWR_LDO_SUPPLY",
        "USE_HAL_DRIVER",
        "STM32H743xx",
        "DEBUG"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/Core/Inc",
          "${workspaceFolder}/USB_DEVICE/App",
          "${workspaceFolder}/USB_DEVICE/Target",
          "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc",
          "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc/Legacy",
          "${workspaceFolder}/Middlewares/ST/STM32_USB_Device_Library/Core/Inc",
          "${workspaceFolder}/Middlewares/ST/STM32_USB_Device_Library/Class/CDC/Inc",
          "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32H7xx/Include",
          "${workspaceFolder}/Drivers/CMSIS/Include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ],
  "version": 4
}
