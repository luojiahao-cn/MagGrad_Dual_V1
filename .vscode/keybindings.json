[
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.tasks.build",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.tasks.runTask",
    "args": "flash",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.tasks.runTask",
    "args": "make clean",
    "when": "editorTextFocus"
  }
]
